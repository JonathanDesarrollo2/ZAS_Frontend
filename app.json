{
  "expo": {
    "name": "ZAS",
    "slug": "Zas_Frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "zasfrontend",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/logo.png",
      "config": {
        "googleMapsApiKey": "AIzaSyCQQVLprlkXfH6sdrNv0VlVSkEN_2_M-eE"
      }
    },
    "android": {
      "package": "com.zas.frontend",
      "adaptiveIcon": {
        "backgroundColor": "#98FFD9",
        "foregroundImage": "./assets/images/logo.png",
        "backgroundImage": "./assets/images/logo.png",
        "monochromeImage": "./assets/images/logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCQQVLprlkXfH6sdrNv0VlVSkEN_2_M-eE"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#98FFD9",
          "image": "./assets/images/logo.png",
          "imageWidth": 120
        }
      ],
      "expo-font",
      "expo-location"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7dcebcd5-cc0a-4a75-9031-42de172a7078"
      }
    }
  }
}